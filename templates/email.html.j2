<!doctype html>
<html>
<body style="margin:0;background:#f4f4f2;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#1a1a1a">
<div style="max-width:600px;margin:0 auto;padding:28px 18px">
  <div style="font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:#b4532a;font-weight:700">Tech Politics Brief</div>
  <h1 style="font-size:24px;margin:4px 0 2px">Daily Top 5</h1>
  <div style="color:#6b6b6b;font-size:13px;margin-bottom:18px">{{ date }} · editor: {{ editor }}</div>

  {% if not items %}
  <p style="color:#6b6b6b">No items today — sources may be unreachable, or nothing cleared the recency window.</p>
  {% endif %}
  {% for it in items %}
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#ffffff;border:1px solid #e6e6e2;border-radius:12px;margin:0 0 14px">
    <tr><td style="padding:18px 20px">
      <div style="font-size:13px;color:#b4532a;font-weight:700;margin-bottom:4px">{{ it.rank }} · {{ it.source_tier | upper }}</div>
      <a href="{{ it.url }}" style="font-size:18px;font-weight:700;color:#1a1a1a;text-decoration:none;line-height:1.3">{{ it.title }}</a>
      <div style="font-size:13px;color:#6b6b6b;margin-top:4px">{{ it.source_name }}{% if it.published %} · {{ it.published }}{% endif %}</div>
      {% if it.carousel_hook %}
      <div style="margin:12px 0 4px;padding:10px 12px;border-left:3px solid #b4532a;background:#f0e2da;border-radius:0 6px 6px 0;font-weight:600">🎞 {{ it.carousel_hook }}</div>
      {% endif %}
      {% if it.why_it_matters %}<p style="margin:8px 0 0;font-size:14px"><b style="color:#6b6b6b">Why it matters —</b> {{ it.why_it_matters }}</p>{% endif %}
      {% if it.key_takeaways %}
      <ul style="margin:10px 0 0;padding:0 0 0 18px;font-size:14px">
        {% for t in it.key_takeaways %}<li style="margin:4px 0">{{ t }}</li>{% endfor %}
      </ul>
      {% endif %}
      {% if it.thesis %}
      <div style="margin-top:10px;font-size:13px;padding:8px 10px;border:1px dashed #e6e6e2;border-radius:8px">
        Thesis: <b>{{ it.thesis.label }}</b> “{{ it.thesis.claim }}”
      </div>
      {% endif %}
      <div style="margin-top:12px;font-size:12px;color:#6b6b6b">
        relevance {{ it.scores.relevance }}/5 · novelty {{ it.scores.novelty }}/5 · carousel {{ it.scores.carousel }}/5 · composite {{ it.composite_pct }}/100 ·
        {% if it.is_everywhere %}already everywhere ({{ it.sources_count }} sources){% else %}fresh ({{ it.sources_count }} src){% endif %}
      </div>
    </td></tr>
  </table>
  {% endfor %}

  <div style="text-align:center;color:#9a9a9a;font-size:11px;margin-top:22px">
    Primary + secondary tech-policy sources · scored &amp; thesis-matched by Tech Politics Brief.
  </div>
</div>
</body>
</html>
