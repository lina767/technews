<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Tech Politics — Daily Top 5 · {{ date }}</title>
<style>
  :root {
    --bg: #f7f7f5; --panel: #ffffff; --ink: #1a1a1a; --muted: #6b6b6b;
    --line: #e6e6e2; --accent: #b4532a; --accent-soft: #f0e2da;
    --good: #2f7d5b; --bad: #b23b3b; --neutral: #6b6b6b; --bar: #e6e6e2;
    --shadow: 0 1px 2px rgba(0,0,0,.05), 0 8px 24px rgba(0,0,0,.04);
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #14140f; --panel: #1d1d18; --ink: #ece9e2; --muted: #a09a8e;
      --line: #2c2c25; --accent: #e0824f; --accent-soft: #322019;
      --good: #6cc79a; --bad: #e07a7a; --neutral: #a09a8e; --bar: #2c2c25;
      --shadow: 0 1px 2px rgba(0,0,0,.3), 0 8px 24px rgba(0,0,0,.3);
    }
  }
  :root[data-theme="dark"] {
    --bg: #14140f; --panel: #1d1d18; --ink: #ece9e2; --muted: #a09a8e;
    --line: #2c2c25; --accent: #e0824f; --accent-soft: #322019;
    --good: #6cc79a; --bad: #e07a7a; --neutral: #a09a8e; --bar: #2c2c25;
  }
  :root[data-theme="light"] {
    --bg: #f7f7f5; --panel: #ffffff; --ink: #1a1a1a; --muted: #6b6b6b;
    --line: #e6e6e2; --accent: #b4532a; --accent-soft: #f0e2da;
    --good: #2f7d5b; --bad: #b23b3b; --neutral: #6b6b6b; --bar: #e6e6e2;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0; background: var(--bg); color: var(--ink);
    font: 16px/1.55 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
  }
  .wrap { max-width: 760px; margin: 0 auto; padding: 40px 20px 72px; }
  header { margin-bottom: 28px; }
  .kicker { font-size: 13px; letter-spacing: .12em; text-transform: uppercase; color: var(--accent); font-weight: 700; }
  h1 { font-size: 30px; line-height: 1.15; margin: 6px 0 4px; letter-spacing: -.01em; }
  .sub { color: var(--muted); font-size: 14px; }
  .card {
    background: var(--panel); border: 1px solid var(--line); border-radius: 14px;
    padding: 20px 22px; margin: 16px 0; box-shadow: var(--shadow);
  }
  .top { display: flex; gap: 14px; align-items: flex-start; }
  .rank {
    flex: 0 0 auto; width: 34px; height: 34px; border-radius: 9px;
    background: var(--accent); color: #fff; font-weight: 800; font-size: 16px;
    display: grid; place-items: center;
  }
  .card h2 { font-size: 19px; line-height: 1.3; margin: 0 0 6px; }
  .card h2 a { color: var(--ink); text-decoration: none; }
  .card h2 a:hover { color: var(--accent); }
  .meta { font-size: 13px; color: var(--muted); display: flex; flex-wrap: wrap; gap: 8px 12px; align-items: center; }
  .tier { font-size: 11px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
    padding: 2px 7px; border-radius: 6px; background: var(--accent-soft); color: var(--accent); }
  .chips { display: flex; flex-wrap: wrap; gap: 6px; margin: 10px 0 0; }
  .chip { font-size: 12px; color: var(--muted); border: 1px solid var(--line); border-radius: 20px; padding: 2px 10px; }
  .hook {
    margin: 14px 0 4px; padding: 11px 14px; border-left: 3px solid var(--accent);
    background: var(--accent-soft); border-radius: 0 8px 8px 0; font-weight: 600; font-size: 15px;
  }
  .why { margin: 10px 0 0; color: var(--ink); font-size: 15px; }
  .why b { color: var(--muted); font-weight: 600; }
  .thesis { margin-top: 12px; font-size: 14px; padding: 10px 12px; border: 1px dashed var(--line); border-radius: 9px; }
  .rel { font-weight: 700; }
  .rel.supports { color: var(--good); }
  .rel.contradicts { color: var(--bad); }
  .rel.extends, .rel.neutral { color: var(--neutral); }
  .scores { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 16px; }
  .metric { font-size: 12px; color: var(--muted); }
  .metric .lab { display: flex; justify-content: space-between; margin-bottom: 4px; }
  .track { height: 6px; background: var(--bar); border-radius: 4px; overflow: hidden; }
  .fill { height: 100%; background: var(--accent); border-radius: 4px; }
  .footline { display: flex; justify-content: space-between; align-items: center; margin-top: 14px;
    padding-top: 12px; border-top: 1px solid var(--line); font-size: 12px; color: var(--muted); }
  .everywhere { color: var(--bad); font-weight: 600; }
  .fresh { color: var(--good); font-weight: 600; }
  .empty { text-align: center; color: var(--muted); padding: 60px 0; }
  footer { margin-top: 36px; text-align: center; color: var(--muted); font-size: 12px; }
  a { color: var(--accent); }
</style>
<script>
  window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
</script>
<script defer src="https://cdn.vercel-insights.com/v1/script.js"></script>
</head>
<body>
<div class="wrap">
  <header>
    <div class="kicker">Tech Politics Brief</div>
    <h1>Daily Top 5</h1>
    <div class="sub">{{ date }} · generated {{ generated_at }} · editor: {{ editor }}</div>
  </header>

  {% if items %}
  {% for it in items %}
  <article class="card">
    <div class="top">
      <div class="rank">{{ it.rank }}</div>
      <div style="min-width:0">
        <h2><a href="{{ it.url }}" target="_blank" rel="noopener">{{ it.title }}</a></h2>
        <div class="meta">
          <span class="tier">{{ it.source_tier }}</span>
          <span>{{ it.source_name }}</span>
          {% if it.published %}<span>· {{ it.published }}</span>{% endif %}
        </div>
      </div>
    </div>

    {% if it.topics %}
    <div class="chips">
      {% for t in it.topics %}<span class="chip">{{ t }}</span>{% endfor %}
    </div>
    {% endif %}

    {% if it.carousel_hook %}<div class="hook">🎞 {{ it.carousel_hook }}</div>{% endif %}
    {% if it.why_it_matters %}<p class="why"><b>Why it matters —</b> {{ it.why_it_matters }}</p>{% endif %}

    {% if it.thesis %}
    <div class="thesis">
      Thesis: <span class="rel {{ it.thesis.relation }}">{{ it.thesis.label }}</span>
      “{{ it.thesis.claim }}”
      {% if it.thesis.note %}<div style="margin-top:4px;color:var(--muted)">{{ it.thesis.note }}</div>{% endif %}
    </div>
    {% endif %}

    <div class="scores">
      {% set m = [
        ('Relevance', it.scores.relevance),
        ('Novelty', it.scores.novelty),
        ('Carousel', it.scores.carousel)
      ] %}
      {% for name, val in m %}
      <div class="metric">
        <div class="lab"><span>{{ name }}</span><span>{{ val }}/5</span></div>
        <div class="track"><div class="fill" style="width: {{ (val/5*100)|round }}%"></div></div>
      </div>
      {% endfor %}
    </div>

    <div class="footline">
      <span>Composite {{ it.composite_pct }}/100 · {{ it.scorer }}</span>
      {% if it.is_everywhere %}
        <span class="everywhere">● Already everywhere · {{ it.sources_count }} sources</span>
      {% else %}
        <span class="fresh">● Fresh · {{ it.sources_count }} source{{ 's' if it.sources_count != 1 else '' }}</span>
      {% endif %}
    </div>
  </article>
  {% endfor %}
  {% else %}
  <div class="empty">No items today — sources may be unreachable, or nothing cleared the recency window.</div>
  {% endif %}

  <footer>
    Surfaced from primary + secondary tech-policy sources · scored for relevance, novelty &amp; carousel-worthiness · matched against your theses.
  </footer>
</div>
</body>
</html>
